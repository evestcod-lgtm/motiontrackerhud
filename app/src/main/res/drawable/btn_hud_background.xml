<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/hud_green_dim" />
            <stroke android:width="1.5dp" android:color="@color/hud_green_bright" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/hud_panel_bg" />
            <stroke android:width="1.5dp" android:color="@color/hud_border" />
        </shape>
    </item>
</selector>
