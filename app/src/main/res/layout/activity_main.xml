<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hud_background">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.motiontracker.hud.overlay.HudOverlayView
        android:id="@+id/hudOverlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top status bar: system status + FPS + zoom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/panel_hud_background"
            android:text="@string/status_searching"
            android:textColor="@color/hud_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textSize="@dimen/hud_text_medium" />

        <TextView
            android:id="@+id/fpsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/panel_hud_background"
            android:text="FPS 0"
            android:textColor="@color/hud_text_secondary"
            android:fontFamily="monospace"
            android:textSize="@dimen/hud_text_small" />

        <TextView
            android:id="@+id/zoomLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/panel_hud_background"
            android:text="1.0x"
            android:textColor="@color/hud_text_secondary"
            android:fontFamily="monospace"
            android:textSize="@dimen/hud_text_small" />
    </LinearLayout>

    <!-- Bottom telemetry + controls panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Sensitivity slider row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_hud_background"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_sensitivity"
                android:textColor="@color/hud_text_secondary"
                android:fontFamily="monospace"
                android:textSize="@dimen/hud_text_small"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/sensitivitySeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/hud_green"
                android:thumbTint="@color/hud_green_bright" />

            <TextView
                android:id="@+id/confidenceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONF —"
                android:textColor="@color/hud_text_secondary"
                android:fontFamily="monospace"
                android:textSize="@dimen/hud_text_small"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Control buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="6">

            <Button
                android:id="@+id/zoomOutButton"
                android:layout_width="@dimen/hud_button_size"
                android:layout_height="@dimen/hud_button_size"
                android:layout_weight="1"
                android:background="@drawable/btn_hud_background"
                android:text="@string/btn_zoom_out"
                android:textColor="@color/hud_green"
                android:textSize="22sp"
                android:textStyle="bold"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp" />

            <Button
                android:id="@+id/zoomInButton"
                android:layout_width="@dimen/hud_button_size"
                android:layout_height="@dimen/hud_button_size"
                android:layout_weight="1"
                android:background="@drawable/btn_hud_background"
                android:text="@string/btn_zoom_in"
                android:textColor="@color/hud_green"
                android:textSize="22sp"
                android:textStyle="bold"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp" />

            <ImageButton
                android:id="@+id/pauseButton"
                android:layout_width="@dimen/hud_button_size"
                android:layout_height="@dimen/hud_button_size"
                android:layout_weight="1"
                android:background="@drawable/btn_hud_background"
                android:contentDescription="@string/btn_pause"
                android:src="@android:drawable/ic_media_pause"
                app:tint="@color/hud_green" />

            <ImageButton
                android:id="@+id/resetButton"
                android:layout_width="@dimen/hud_button_size"
                android:layout_height="@dimen/hud_button_size"
                android:layout_weight="1"
                android:background="@drawable/btn_hud_background"
                android:contentDescription="@string/btn_reset"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/hud_green" />

            <ImageButton
                android:id="@+id/screenshotButton"
                android:layout_width="@dimen/hud_button_size"
                android:layout_height="@dimen/hud_button_size"
                android:layout_weight="1"
                android:background="@drawable/btn_hud_background"
                android:contentDescription="@string/btn_screenshot"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/hud_green" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
